# ─── E2E Rebalancer Test Environment ─────────────────────────────────────────
# Copy to .env or source before running:
#   cp .env.e2e .env
#   yarn e2e --run-modes methOnly --dry-run
#
# Prerequisites:
#   1. PostgreSQL: yarn workspace @mark/database db:setup
#   2. Redis:      yarn redis:up

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=mainnet
STAGE=development
LOG_LEVEL=info

# ─── Wallet ──────────────────────────────────────────────────────────────────
# Test wallet private key (hex). For dry-run, this just needs to be a valid key
# to initialize adapters — no real transactions are submitted
WEB3_SIGNER_PRIVATE_KEY=
SIGNER_URL=
SIGNER_ADDRESS=
SOL_SIGNER_ADDRESS=

# ─── RPC Providers ───────────────────────────────────────────────────────────
# At minimum, provide chains used by the rebalancers you want to test.
# mETH rebalancer uses chains 1 (ETH mainnet) and 5000 (Mantle)
CHAIN_1_PROVIDERS=https://1rpc.io/eth
CHAIN_5000_PROVIDERS=https://mantle.drpc.org

# TAC rebalancer (if testing tacOnly)
# CHAIN_728126428_PROVIDERS=  # Tron

# Solana (if testing solanaUsdcOnly)
SOLANA_PRIVATE_KEY=# base58 Solana private key
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
CHAIN_1399811149_PROVIDERS=https://api.mainnet-beta.solana.com

# ─── Chain Configuration ────────────────────────────────────────────────────
CHAIN_IDS=1,5000,1399811149
SUPPORTED_SETTLEMENT_DOMAINS=1,5000
SUPPORTED_ASSET_SYMBOLS=USDC,USDT,WETH

# Chain assets (format: SYMBOL,address,decimals,ticker,isNative)
CHAIN_1_ASSETS=USDC,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,6,USDC,false;WETH,0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2,18,WETH,false;USDT,0xdAC17F958D2ee523a2206206994597C13D831ec7,6,USDT,false
CHAIN_5000_ASSETS=USDC,0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9,6,USDC,false;WETH,0xdEAddEaDdeadDEadDEADDEAddEADDEAddead1111,18,WETH,false;USDT,0x201EBa5CC46D216Ce6DC03F6a759e8E766e956aE,6,USDT,false

# ─── Database ────────────────────────────────────────────────────────────────
# Uses the same DB as local dev (docker-compose on port 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mark_dev?sslmode=disable
DATABASE_MIGRATION_PATH=db/migrations

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Metrics (disabled for testing) ─────────────────────────────────────────
PUSH_GATEWAY_URL=http://localhost:9091
PROMETHEUS_ENABLED=false

# ─── Everclear API ──────────────────────────────────────────────────────────
# Not needed for rebalance-only testing, but required by config loader
EVERCLEAR_API_URL=https://api.everclear.org

# ─── Routes ─────────────────────────────────────────────────────────────────
# Leave unset — routes are not needed for rebalancer-only testing.
# Falls back to S3 then to empty routes, which is fine.
# ROUTES_LOCAL_YAML=

# ─── mETH Rebalancer ────────────────────────────────────────────────────────
METH_REBALANCE_ENABLED=true
METH_REBALANCE_MARKET_MAKER_ADDRESS=
METH_REBALANCE_MARKET_MAKER_ON_DEMAND_ENABLED=false
METH_REBALANCE_MARKET_MAKER_THRESHOLD_ENABLED=false
METH_REBALANCE_FILL_SERVICE_ADDRESS=
METH_REBALANCE_FILL_SERVICE_THRESHOLD_ENABLED=true
METH_REBALANCE_FILL_SERVICE_THRESHOLD=999000000000000000000
METH_REBALANCE_FILL_SERVICE_TARGET_BALANCE=999000000000000000000
METH_REBALANCE_BRIDGE_MIN_REBALANCE_AMOUNT=100000000000000
METH_REBALANCE_BRIDGE_MAX_REBALANCE_AMOUNT=100000000000000
METH_REBALANCE_BRIDGE_SLIPPAGE_DBPS=500

# ─── Solana ptUSDe Rebalancer ───────────────────────────────────────────────
SOLANA_PTUSDE_REBALANCE_ENABLED=true
SOLANA_PTUSDE_REBALANCE_THRESHOLD=1000000000
SOLANA_PTUSDE_REBALANCE_TARGET=1000000000
SOLANA_PTUSDE_REBALANCE_BRIDGE_MIN_REBALANCE_AMOUNT=100000
SOLANA_PTUSDE_REBALANCE_BRIDGE_MAX_REBALANCE_AMOUNT=100000
SOLANA_PTUSDE_REBALANCE_BRIDGE_SLIPPAGE_DBPS=500

# ─── Other Rebalancers (disabled) ──────────────────────────────────────────
TAC_REBALANCE_ENABLED=false
AMANUSDE_REBALANCE_ENABLED=false
AMANSYRUPUSDT_REBALANCE_ENABLED=false

# ─── E2E Runner Defaults ────────────────────────────────────────────────────
# These can also be set via CLI flags (--dry-run, --config)
# DRY_RUN=true
# E2E_CONFIG_PATH=./e2e-config.example.json
